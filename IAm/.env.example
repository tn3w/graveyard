# Database URL (SQLite)
DATABASE_URL=sqlite:auth.db?mode=rwc

# JWT Secret (generate a secure random string, at least 64 characters)
JWT_SECRET=your-super-secure-jwt-secret-key-here-make-it-long-and-random

# Session Key (generate a secure random string, at least 64 characters)
SESSION_KEY=your-super-secure-session-key-here-make-it-long-and-random